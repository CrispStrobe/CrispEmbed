error: no model specified (-m)
Usage: build/crispembed -m MODEL [options] [TEXT ...]

Options:
  -m MODEL         path to GGUF model or model name (auto-download)
  -f FILE          read texts from file (one per line)
  -t N             number of threads (default: 4)
  -d N             output dimension (Matryoshka truncation)
  --prefix TEXT    prepend a prefix to all inputs before tokenization
  --json           output as JSON array
  --dim            print embedding dimension and exit
  --capabilities   print model capability flags and exit
  --sparse         encode sparse term-weight vectors
  --colbert        encode ColBERT per-token vectors
  --audio FILE     encode raw 16 kHz mono float32 PCM (.raw); cross-modal embedding
  --image-raw FILE encode preprocessed image patches as float32 rows
  --grid-thw T,H,W image patch grid for --image-raw
  --image FILE     encode JPG/PNG/BMP via in-process preprocessor (cross-modal embedding)
  --rerank QUERY   cross-encoder rerank documents against QUERY
  --biencoder QUERY  bi-encoder rerank documents against QUERY
  --top-n N        limit rerank output to top N documents
  --face FILE      encode face from image (recognition model)
  --detect FILE    detect faces in image (detection model)
  --ocr FILE       OCR → text (auto-detect: pix2tex/hmer/bttr/posformer/ppformulanet/ppformulanet-l/texo/mixtex/parseq/qwen2vl/internvl2/glm-ocr/tesseract-lstm)
  --hmer FILE      handwritten math OCR → LaTeX (HMER model)
  --bttr FILE      handwritten math OCR → LaTeX (BTTR model)
  --layout FILE    document layout detection (RT-DETRv2, needs -m layout_model.gguf)
  --ner TEXT       named entity recognition (GLiNER, needs -m ner_model.gguf)
  --ner-labels L   comma-separated entity types (default: person,organization,location)
  --ner-threshold F  confidence threshold for NER (default: 0.5)
  --kie FILE       key information extraction: OCR + NER on a document image
                   needs -m ner_model.gguf --ocr-det det.gguf --ocr-rec rec.gguf
  --kie-labels L   comma-separated field names (default: uses --ner-labels)
  --kie-threshold F  confidence threshold for KIE (default: 0.5)
  --det MODEL      detection model for --face-pipeline
  --face-pipeline  detect+align+encode faces (needs -m rec_model --det det_model)
  --punct-model M  post-process OCR text with punctuation model (FireRedPunc/PCS)
  --output-format F  OCR output format: text (default), hocr, alto
  --find-skew FILE   detect skew angle (degrees) of a document image
  --dewarp FILE      dewarp a curved document page (straighten text lines)
  --tps-dewarp MODEL FILE  TPS-based dewarp (learned, needs model GGUF)
  --cc-detect FILE   detect text lines via connected components (model-free)
  --cleanup        preprocess scan before OCR (deskew, crop borders, whiten background)
  --cleanup-only F process scan and write cleaned image to stdout (no OCR)
  --ocr-pipeline F full OCR pipeline: source-type routing + cleanup + accept-gate
       --ocr-engine N  primary engine (dbnet_trocr|surya|tesseract|got|glm|qwen2vl|internvl2)
       --denoise       NAFNet pre-processor; --punct-model M  post-OCR punctuation/spacing
       --sr-model PATH text super-resolution GGUF for low-DPI upscaling (NAFNet+PixelShuffle)
  --ocr-det MODEL  general OCR: text detection model (DBNet/surya-det)
  --ocr-rec MODEL  general OCR: text recognition model (TrOCR, e.g. trocr-printed)
                   use with --ocr IMAGE: detects text regions then recognizes each crop
  --conf N         confidence threshold for detection (default: 0.5)
  --auto-download  download model automatically if not found
  --accept-license SPDX  pre-accept a restricted license (e.g. cc-by-nc-4.0, gemma)
                          required for non-commercial / vendor-licensed models in non-TTY mode.
                          alternatively set the CRISPEMBED_ACCEPT_LICENSE env var.
  --list-models    list available models (license column marks * for restricted)
  --cache-dir DIR  set model cache directory

